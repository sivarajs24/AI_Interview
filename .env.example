# Flask configuration
FLASK_ENV=development
SECRET_KEY=replace-with-a-strong-random-secret
PORT=5000

# Socket.IO async mode (eventlet is included in requirements)
SOCKETIO_ASYNC_MODE=eventlet

# Local Qwen LLM settings
QWEN_ENABLED=true
QWEN_PRIMARY_MODEL=Qwen/Qwen2.5-3B-Instruct
QWEN_FALLBACK_MODEL=Qwen/Qwen2.5-1.5B-Instruct
QWEN_TIMEOUT_SECONDS=12
QWEN_GPU_LOW_VRAM_MB=1600
QWEN_MAX_NEW_TOKENS=220
QWEN_TEMPERATURE=0.7
